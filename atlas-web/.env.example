# Backend API base used by atlas-web
VITE_API_BASE_URL=http://127.0.0.1:3100/api

# Public base URL of the web app itself (used for OAuth callback URL construction/debugging)
VITE_APP_BASE_URL=http://127.0.0.1:5173

# Preferred frontend callback URL when the backend does not expose /api/auth/wework/url yet
VITE_WECOM_REDIRECT_URI=http://127.0.0.1:5173/auth/callback

# Optional fallback-only OAuth construction values for early Sprint 2 integration.
# Prefer backend-generated auth URL when available.
VITE_WECOM_CORP_ID=
VITE_WECOM_AGENT_ID=

# Keep mock login behind an explicit env switch during Sprint 2 auth rollout
VITE_ENABLE_MOCK_LOGIN=false
