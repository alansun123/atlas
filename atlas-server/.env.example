PORT=3000

# JWT/Token secret for signing Atlas access tokens. Used for backend-issued sessions.
# (Also reads from ATLAS_AUTH_TOKEN_SECRET for backwards compatibility.)
JWT_SECRET=
ATLAS_AUTH_TOKEN_SECRET=atlas-dev-secret-change-me
ATLAS_AUTH_TOKEN_TTL_SECONDS=7200

# WeCom auth mode:
# - auto: use real WeCom exchange when credentials exist, otherwise fall back to stub mode
# - real: require real credential-backed exchange
# - stub: resolve identities from ATLAS_WECOM_CODE_MAP or stub:<weworkUserId>
# - env: force a single stub user from ATLAS_WECOM_STUB_USER_ID
ATLAS_WECOM_AUTH_MODE=auto

# Real WeCom OAuth / code-exchange contract.
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_SECRET=
WECOM_REDIRECT_URI=
WECOM_SCOPE=snsapi_base
WECOM_STATE=atlas

# Optional endpoint overrides for local smoke/integration tests.
ATLAS_WECOM_ACCESS_TOKEN_URL=https://qyapi.weixin.qq.com/cgi-bin/gettoken
ATLAS_WECOM_USERINFO_URL=https://qyapi.weixin.qq.com/cgi-bin/auth/getuserinfo
ATLAS_WECOM_USER_DETAIL_URL=https://qyapi.weixin.qq.com/cgi-bin/user/get
# Default false so shared/acceptance envs cannot silently mask redirect mismatches.
# Set true only for explicit local override-based smoke tests.
ATLAS_WECOM_ALLOW_REDIRECT_OVERRIDE=false

# Stub mode mapping. Example JSON:
# {"callback_code":{"weworkUserId":"manager_zhangsan","name":"张三"}}
ATLAS_WECOM_CODE_MAP=

# Optional env-mode fallback when ATLAS_WECOM_AUTH_MODE=env
ATLAS_WECOM_STUB_USER_ID=
ATLAS_WECOM_STUB_USER_NAME=
